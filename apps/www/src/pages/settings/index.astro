---
import Base from "@layouts/Base.astro";

const title = "Settings";
---

<Base title={title}>
  <main class="min-h-[60vh] container-xl py-10">
    <section class="max-w-2xl">
      <p class="text-xs uppercase tracking-[0.25em] text-slate-500 mb-2">Account</p>
      <h1 class="text-3xl font-semibold text-white mb-3">{title}</h1>
      <p class="text-slate-400 mb-8">
        Basic account settings placeholder. You can extend this page with
        profile, notification, or workspace preferences later.
      </p>
    </section>
  </main>
</Base>

